# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SESSION_SECRET="your-32-character-session-secret-here"
NODE_ENV="development"

# --- SUPABASE CONFIG ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- WHATSAPP CONFIG ---
WHATSAPP_VERIFY_TOKEN="your-whatsapp-verify-token"
WHATSAPP_ACCESS_TOKEN="your-system-user-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-waba-id"

# --- META ADS ---
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
# Business Login config for Meta Ads OAuth (from App > Facebook Login for Business > Configurations)
NEXT_PUBLIC_FB_CONFIG_ID="your-meta-ads-config-id"
# Embedded Signup config for WhatsApp (from App > WhatsApp > Configuration — needs whatsapp_business_management + whatsapp_business_messaging)
NEXT_PUBLIC_WA_CONFIG_ID="your-whatsapp-embedded-signup-config-id"

# --- RAZORPAY ---
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# --- UPSTASH / QSTASH ---
UPSTASH_REDIS_REST_URL="https://your-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

